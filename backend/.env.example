
#
# Render + Railway example environment
# Copy these values into your Render backend service environment variables.
# Do not commit your real .env file.
#

# Database
# Option A: set one SQLAlchemy connection string.
# If Railway gives you mysql://..., the backend will auto-convert it to mysql+pymysql://...
DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DATABASE

# Option B: set individual Render-style variables by copying the values from Railway.
DB_HOST=containers-us-west-xxx.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=railway

# The backend also understands Railway's native MYSQLHOST / MYSQLPORT / MYSQLUSER /
# MYSQLPASSWORD / MYSQLDATABASE names if you prefer to use those directly.

# Frontend origin(s) allowed to call this API
# Comma-separated list. Add your local frontend too if you still test locally.
CORS_ALLOW_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# OpenAI chatbot
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Email / SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_app_password

# Admin demo account
ADMIN_EMAIL=admin@flipkart.com
ADMIN_PASSWORD=admin123

# Render provides PORT automatically. Do not set it manually unless you have a special reason.
